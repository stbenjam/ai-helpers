{
  "allowed_bots": [
    {
      "author": "coderabbitai[bot]",
      "description": "CodeRabbit AI reviewer — classify substantive review comments (code issues, suggestions, questions)"
    }
  ],
  "noise_patterns": [
    "No actionable comments were generated",
    "Skipped: comment is from another GitHub bot",
    "<!-- walkthrough_start -->",
    "skip review by coderabbit.ai"
  ],
  "severity": [
    {
      "value": "nitpick",
      "description": "Cosmetic or stylistic preference — take it or leave it",
      "signals": ["nit:", "minor:", "optional", "could also", "personal preference"]
    },
    {
      "value": "suggestion",
      "description": "Worth considering but not blocking merge",
      "signals": ["consider", "might want to", "could", "what about", "have you thought about"]
    },
    {
      "value": "required_change",
      "description": "Must be addressed before merge — blocking",
      "signals": ["this will break", "bug", "needs to be fixed", "must", "fails", "panic", "crash"]
    },
    {
      "value": "question",
      "description": "Reviewer is asking for clarification or understanding",
      "signals": ["why", "what does", "can you explain", "how does", "is this intentional"]
    },
    {
      "value": "unclassified",
      "description": "Meta-comments, acknowledgments, or does not fit above categories",
      "signals": ["looks good", "thanks", "LGTM", "acknowledged"]
    }
  ],
  "topic": [
    {
      "value": "style",
      "description": "Code formatting, naming, organization, idioms",
      "examples": ["rename variable", "move to var block", "use consistent casing", "reorder imports"]
    },
    {
      "value": "logic_bug",
      "description": "Incorrect logic, potential bugs, edge cases, nil panics, race conditions",
      "examples": ["nil pointer dereference", "off-by-one", "case mismatch", "missing error check"]
    },
    {
      "value": "test_gap",
      "description": "Missing tests, test quality, coverage issues, failing tests",
      "examples": ["add a test for empty input", "unit tests failing", "test doesn't validate X"]
    },
    {
      "value": "api_design",
      "description": "API surface, interfaces, abstractions, contracts, exported types",
      "examples": ["why is this exported?", "consider a different signature", "interface too broad"]
    },
    {
      "value": "architecture_design",
      "description": "System architecture, component boundaries, patterns, layering, coupling",
      "examples": ["this belongs in the controller", "separate concerns", "wrong abstraction layer", "circular dependency"]
    },
    {
      "value": "security",
      "description": "Security vulnerabilities, auth issues, input validation, secrets handling",
      "examples": ["SQL injection", "unsanitized input", "hardcoded secret", "missing RBAC check", "privilege escalation"]
    },
    {
      "value": "documentation",
      "description": "Missing docs, comments, READMEs, godoc",
      "examples": ["missing godoc", "add a comment explaining why", "update README"]
    },
    {
      "value": "ci",
      "description": "CI triggers, test results, overrides, retests, pipeline issues",
      "examples": ["/test e2e-aws", "e2e failed on Teardown", "rebase to fix CI", "konflux issues"]
    },
    {
      "value": "approval",
      "description": "Approvals, LGTMs, sign-offs, acknowledgments",
      "examples": ["/lgtm", "no changes requested", "LGTM", "looks good to me"]
    },
    {
      "value": "process",
      "description": "Jira refs, duplicates, PR status, meta-discussion, code not pushed",
      "examples": ["dup of #7727", "Jira validation", "code not pushed", "close this PR"]
    },
    {
      "value": "unclassified",
      "description": "Does not fit other categories — catch-all",
      "examples": []
    }
  ]
}
